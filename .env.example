# Anthropic API
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# PolicyEngine UK data (required for economy-wide simulations)
POLICYENGINE_UK_DATA_TOKEN=your_token_here

# Backend URL used by the Next.js proxy route
BACKEND_URL=http://localhost:8001

# Optional direct browser override for backend requests
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

APP_URL=http://localhost:3000
GITHUB_REPORT_REPO=PolicyEngine/policyengine-uk-chat

# Database
DB_NAME=microsim
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Supabase (frontend auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
